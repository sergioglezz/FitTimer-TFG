<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AlimentacionFragment">

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="125dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnDefinicion"
            android:layout_width="175dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:backgroundTint="#03A9F4"
            android:fontFamily="@font/amiko_bold"
            android:background="@drawable/rounded_edittext_background"
            android:text="Definición" />

        <Button
            android:id="@+id/btnVolumen"
            android:layout_width="175dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#03A9F4"
            android:fontFamily="@font/amiko_bold"
            android:background="@drawable/rounded_edittext_background"

            android:text="Volumen" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="468dp"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView1"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardBackgroundColor="#B17A7A"
                app:cardCornerRadius="25dp">

                <ImageView
                    android:id="@+id/imageView1"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/grilledchickensalad" />

                <TextView
                    android:id="@+id/textView1"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:gravity="left"
                    android:text="Ensalada de Pollo a la Parrilla"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="390 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView2"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <!-- Contenido de la tarjeta 1 -->

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/quinoaconverdurasemplatada" />

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:gravity="left"
                    android:text="Tazón de Quinoa y Vegetales"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView4"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="433 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView3"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/batidoverde" />

                <TextView
                    android:id="@+id/textView5"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:gravity="left"
                    android:text="Smoothie Verde Energético"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="252 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView4"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <!-- Contenido de la tarjeta 1 -->

                <ImageView
                    android:id="@+id/imageView4"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/salmonalhorno" />

                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:gravity="left"
                    android:text="Salmón al Horno con Espárragos"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="445 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView5"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardBackgroundColor="#B17A7A"
                app:cardCornerRadius="25dp">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/c4cc16012490b66d5a8655338e3f5023" />

                <TextView
                    android:id="@+id/textView9"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:text="Smoothie de Avena y Frutas"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="1070 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView6"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <!-- Contenido de la tarjeta 1 -->

                <ImageView
                    android:id="@+id/imageView6"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pasta" />

                <TextView
                    android:id="@+id/textView11"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:text="Pasta con Pollo y Salsa Alfredo"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView12"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="1824 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView7"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <!-- Contenido de la tarjeta 1 -->

                <ImageView
                    android:id="@+id/imageView7"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/hamburgesa" />

                <TextView
                    android:id="@+id/textView13"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:text="Hamburguesa con Guacamole y Papas"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView14"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="1589 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView8"
                android:layout_width="175dp"
                android:layout_height="175dp"
                android:layout_margin="8dp"
                android:backgroundTint="#FFFFFF"
                android:layoutDirection="inherit"
                app:cardCornerRadius="25dp">

                <!-- Contenido de la tarjeta 1 -->

                <ImageView
                    android:id="@+id/imageView8"
                    android:layout_width="175dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:cropToPadding="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/lasana" />

                <TextView
                    android:id="@+id/textView15"
                    android:layout_width="165dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|center"
                    android:layout_marginBottom="30dp"
                    android:text="Lasagna de Carne y Queso"
                    android:textAlignment="viewStart"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textView16"
                    android:layout_width="165dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|center"
                    android:text="3690 kcal"
                    android:textColor="#03A9F4" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
