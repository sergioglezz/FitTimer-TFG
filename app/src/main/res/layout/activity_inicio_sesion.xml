<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo">


    <androidx.cardview.widget.CardView
        android:id="@+id/CardViewAtras"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#367FB5"
        android:orientation="horizontal"
        app:cardCornerRadius="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:srcCompat="@drawable/atras" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="90dp"
            android:layout_height="60dp"
            android:layout_gravity="right"
            android:fontFamily="@font/amiko_bold"
            android:gravity="center|right"
            android:text="Atrás"
            android:textAlignment="center"
            android:textColor="#FEFEFE"
            android:textSize="25sp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/CardViewRegistro"
        android:layout_width="380dp"
        android:layout_height="450dp"
        android:layout_marginTop="150dp"
        app:cardBackgroundColor="#3680B6"
        app:cardCornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            tools:layout_editor_absoluteX="match_parent"
            tools:layout_editor_absoluteY="match_parent">

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:fontFamily="@font/amiko_bold"
                android:gravity="center"
                android:text="Inicia sesion"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="45sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:fontFamily="@font/amiko_bold"
                android:gravity="center"
                android:text="Nombre de usuario"
                android:textAlignment="center"
                android:textColor="#FEFEFE"
                android:textSize="24sp" />

            <EditText
                android:id="@+id/nombreEditText"
                android:layout_width="325dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/rounded_edittext_background"
                android:ems="10"
                android:fontFamily="@font/amiko_bold"
                android:inputType="text"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="#256E8D"
                android:textColorHint="#FFFFFF"
                android:textSize="24sp"
                tools:text="Nombre de usuario" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:fontFamily="@font/amiko_bold"
                android:gravity="center"
                android:text="Contraseña"
                android:textAlignment="center"
                android:textColor="#FEFEFE"
                android:textSize="24sp" />

            <EditText
                android:id="@+id/contrasenaEditText"
                android:layout_width="325dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/rounded_edittext_background"
                android:ems="10"
                android:fontFamily="@font/amiko_bold"
                android:inputType="text"
                android:password="true"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="#256E8D"
                android:textColorHint="#FFFFFF"
                android:textSize="24sp"
                tools:text="Contraseña" />

            <Button
                android:id="@+id/RegistroBtn"
                android:layout_width="325dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:layout_marginTop="75px"
                android:background="@drawable/rounded_edittext_background"
                android:backgroundTint="#80FFFFFF"
                android:fontFamily="@font/amiko_bold"
                android:gravity="center"
                android:text="Iniciar Sesion"
                android:textColor="#FEFEFE"
                android:textSize="24sp"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>